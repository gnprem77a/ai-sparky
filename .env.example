# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aisparky

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of your app — used in email links and API responses
APP_URL=https://aisparky.dev
PORT=5000
NODE_ENV=production

# ─── AI Providers ────────────────────────────────────────────────────────────
BLUESMINDS_API_KEY=your_bluesminds_api_key_here

# ─── AWS (optional — for file uploads / S3) ──────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Namecheap Private Email settings:
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=noreply@aisparky.dev
SMTP_PASS=your_email_password_here
# Display name + address shown in the From field
SMTP_FROM=AI Sparky <noreply@aisparky.dev>
